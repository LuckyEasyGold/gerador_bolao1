# Database
DATABASE_URL=postgresql://lotofacil_user:lotofacil_pass@localhost:5432/lotofacil
REDIS_URL=redis://localhost:6379/0

# API
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true

# Security
SECRET_KEY=your-secret-key-here-change-in-production
ALGORITHM=HS256

# Optimization
MAX_WORKERS=4
CACHE_TTL=3600

# Monte Carlo
DEFAULT_SIMULATIONS=10000
RANDOM_SEED=42

# API Caixa
CAIXA_API_BASE_URL=https://servicebus2.caixa.gov.br/portaldeloterias/api
CAIXA_API_TIMEOUT=30
